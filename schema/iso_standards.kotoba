// Iso_standards clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace iso_standards {

    entity Work {
        id: string @unique
        doi: string
        title: string
        type: string
        publishedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Author {
        id: string @unique
        orcid: string
        givenName: string
        familyName: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Citation {
        id: string @unique
        workId: string
        citedDoi: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Standard {
        id: string @unique
        designation: string
        title: string
        organization: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Record {
        id: string @unique
        accession: string
        database: string
        title: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Subject {
        id: string @unique
        workId: string
        term: string
        scheme: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
